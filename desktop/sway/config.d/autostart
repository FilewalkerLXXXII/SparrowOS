# SparrowOS Sway Autostart Configuration
# Applications and environment for the cyberpunk desktop

# ---------------------------------------------------------------------------
# Environment variables
# ---------------------------------------------------------------------------
# Environment variables (set before Sway starts, not via exec)
# These should be in your shell profile or set via systemd environment.d

# ---------------------------------------------------------------------------
# Status bar
# ---------------------------------------------------------------------------
exec_always sh -c 'pkill waybar; waybar &'

# ---------------------------------------------------------------------------
# Notification daemon (install swaync if available)
# ---------------------------------------------------------------------------
# exec swaync

# ---------------------------------------------------------------------------
# Autostart applications
# ---------------------------------------------------------------------------
# Agentic Development Layout on workspace 1
# Launches foot with sparrow-workspace (tmux with editor + terminal + AI agent)
exec swaymsg "workspace 1:term; exec foot sparrow-workspace"

# ---------------------------------------------------------------------------
# Idle / lock management
# ---------------------------------------------------------------------------
exec swayidle -w \
    timeout 300 'swaylock -f -c 0a0a0a' \
    timeout 600 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"'
