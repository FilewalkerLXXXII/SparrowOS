# SparrowOS Sway Autostart Configuration
# Applications and environment for the cyberpunk desktop

# ---------------------------------------------------------------------------
# Environment variables
# ---------------------------------------------------------------------------
exec_always {
    export XDG_CURRENT_DESKTOP=sway
    export XDG_SESSION_TYPE=wayland
    export MOZ_ENABLE_WAYLAND=1
    export QT_QPA_PLATFORM=wayland
    export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
    export SDL_VIDEODRIVER=wayland
    export _JAVA_AWT_WM_NONREPARENTING=1
}

# ---------------------------------------------------------------------------
# Status bar
# ---------------------------------------------------------------------------
exec_always killall waybar; waybar &

# ---------------------------------------------------------------------------
# Notification daemon
# ---------------------------------------------------------------------------
exec swaync

# ---------------------------------------------------------------------------
# Wallpaper
# ---------------------------------------------------------------------------
exec swaybg -i $HOME/.config/sparrow/wallpaper.png -m fill

# ---------------------------------------------------------------------------
# Autostart applications
# ---------------------------------------------------------------------------
# Terminal on workspace 1
exec swaymsg "workspace 1:term; exec foot"

# ---------------------------------------------------------------------------
# Idle / lock management
# ---------------------------------------------------------------------------
exec swayidle -w \
    timeout 300 'swaylock -f -c 0a0a0a' \
    timeout 600 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"' \
    before-sleep 'swaylock -f -c 0a0a0a'
